{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.local/schemas/confidence_report.schema.json",
  "title": "Genesis Confidence Report",
  "type": "object",
  "required": ["schema_version", "artifacts"],
  "properties": {
    "schema_version": { "type": "string" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact", "artifact_type", "source_refs", "confidence", "requires_human_review"],
        "properties": {
          "artifact": { "type": "string" },
          "artifact_type": { "type": "string" },
          "source_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "requires_human_review": { "type": "boolean" },
          "reason": { "type": "string" }
        }
      }
    }
  }
}


{
  "genesis_version": "3.1.0",
  "stage": "decide_design_strategy",
  "pages": {
    "login": {
      "profile": "auth_split_screen",
      "desktop_strategy": "split_screen_balanced",
      "left_panel": "hospital_branding_with_teal_gradient_and_trust_message",
      "right_panel": "login_form_480px_centered",
      "rules": ["form must not feel miniaturized", "left panel provides visual anchor", "composition feels balanced on 1440px"]
    },
    "welcome": {
      "profile": "landing_or_marketing",
      "desktop_strategy": "editorial_capped",
      "max_content_width": "section_based",
      "rules": ["hero must feel intentional", "quick actions clearly visible", "warm healthcare feel"]
    },
    "dashboard": {
      "profile": "portal_dashboard",
      "desktop_strategy": "task_first_wide",
      "max_content_width": "1280px",
      "rules": ["metric cards use horizontal space", "no marketing narrow columns", "sidebar + main content composition"]
    },
    "book": {
      "profile": "operational_form",
      "desktop_strategy": "form_plus_context",
      "max_content_width": "1100px",
      "rules": ["two column layout on desktop when space allows", "all labels visible", "clear submit CTA"]
    },
    "consultations": {
      "profile": "data_table_workspace",
      "desktop_strategy": "dense_workspace",
      "max_content_width": "1400px",
      "rules": ["filter bar above list", "status badges scannable", "full width search input", "each card shows all required fields"]
    },
    "prescriptions": {
      "profile": "operational_form",
      "desktop_strategy": "form_plus_context",
      "max_content_width": "1100px",
      "rules": ["prescription cards per completed consultation", "demo disclaimer prominent", "no real medical advice"]
    },
    "signout": {
      "profile": "landing_or_marketing",
      "desktop_strategy": "centered_confirmation",
      "rules": ["friendly message", "session end confirmation", "return to login action clear"]
    }
  }
}

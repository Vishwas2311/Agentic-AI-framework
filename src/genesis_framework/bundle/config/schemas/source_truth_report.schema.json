{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.local/schemas/source_truth_report.schema.json",
  "title": "Genesis Source Truth Report",
  "type": "object",
  "required": ["schema_version", "decisions"],
  "properties": {
    "schema_version": { "type": "string" },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "artifact_type", "candidate_sources", "winning_source", "confidence", "requires_human_review"],
        "properties": {
          "artifact_id": { "type": "string" },
          "artifact_type": { "type": "string" },
          "candidate_sources": {
            "type": "array",
            "items": { "type": "string" }
          },
          "winning_source": { "type": "string" },
          "reason": { "type": "string" },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "requires_human_review": { "type": "boolean" }
        }
      }
    }
  }
}

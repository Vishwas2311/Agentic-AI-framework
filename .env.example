# NoCode2ProCode-Genesis local credential template
# Copy to .env.local and fill only the integrations approved for this machine.
# Never commit .env.local.

GENESIS_PROFILE=FullLocal
GENESIS_ALLOW_REMOTE_RUNTIME_CAPTURE=false

# Claude / model access
ANTHROPIC_API_KEY=
CLAUDE_CODE_AUTH=use_local_claude_code_login

# Source and design integrations
GITHUB_TOKEN=
FIGMA_ACCESS_TOKEN=
FIRECRAWL_API_KEY=
MAGIC_21ST_API_KEY=
E2B_API_KEY=

# Database / memory integrations
DATABASE_URL_READONLY=
POSTGRES_READONLY_URL=
QDRANT_URL=
QDRANT_API_KEY=

# Security / optional services
SEMGREP_APP_TOKEN=
SNYK_TOKEN=

# Power Platform / low-code platform integrations
POWER_PLATFORM_ENVIRONMENT_ID=
POWER_PLATFORM_TENANT_ID=
POWER_PLATFORM_CLIENT_ID=
POWER_PLATFORM_CLIENT_SECRET=
